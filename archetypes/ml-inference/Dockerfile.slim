# Dockerfile.slim — ML Inference (Image Recognition)
# Minimal dependencies + MobileNetV2 weights only
# Build with: --target lambda-target or --target fargate-target

# ── Shared: download MobileNetV2 weights (~14MB) ────────────────────────────
FROM python:3.11-slim AS model-downloader
RUN pip install --no-cache-dir torch torchvision
RUN mkdir -p /app/models \
    && python -c "\
import torch, torchvision.models as m; \
model = m.mobilenet_v2(weights=m.MobileNet_V2_Weights.DEFAULT); \
torch.save(model.state_dict(), '/app/models/mobilenet_v2.pth')"

# ── Lambda target (CPU-only torch from PyTorch index) ────────────────────────
FROM public.ecr.aws/lambda/python:3.11 AS lambda-target
COPY requirements-slim-lambda.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && rm /tmp/requirements.txt
COPY --from=model-downloader /app/models /var/task/models
ENV MODEL_DIR=/var/task/models
COPY handler.py ${LAMBDA_TASK_ROOT}/
CMD ["handler.handler"]

# ── Fargate target ───────────────────────────────────────────────────────────
FROM python:3.11-slim AS fargate-target
RUN apt-get update && apt-get upgrade -y && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY requirements-slim.txt .
RUN pip install --no-cache-dir -r requirements-slim.txt
COPY --from=model-downloader /app/models /app/models
COPY handler.py .
ENV PLATFORM=fargate
ENV MODEL_DIR=/app/models
EXPOSE 8080
CMD ["python", "handler.py"]
